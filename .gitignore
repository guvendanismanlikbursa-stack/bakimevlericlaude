/vendor
/node_modules
/public/build
.env
database/database.sqlite
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/framework/testing/*
storage/logs/*
# Yukaridaki "*" kurallari .gitkeep'i de hariç tutuyordu - temiz bir git
# clone'da (ör. GitHub Actions) bu klasorler HIC OLUSMUYORDU, "Please
# provide a valid cache path" gibi hatalarla CI'i patlatiyordu (12 Temmuz
# 2026). Klasorlerin en azindan BOS olarak var olmasi icin istisna edildi.
!storage/framework/cache/data/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/logs/.gitkeep

.env.codex-backup
.env.production
database/codex_clean.sqlite
.phpunit.result.cache
composer.phar
tmp_*

# Kurum gorselleri (scrape/import ile gelen, siki takip edilmesi gereken buyuk
# medya) ve public/storage symlink hedefi: repo boyutunu sismesin diye
# versiyon kontrolune alinmiyor, ayri yedeklenmeli. Statik demo-cards haric.
/public/storage
storage/app/public/facilities
storage/app/public/silinenler
storage/app/public/font_test.png
storage/app/public/claims

# Buyuk scrape yedekleri: kaynak veri, ayri saklanmali
database/backups

# Veri cekici (Python) calisma zamani/test artefaktlari
tools/veri-cekici/__pycache__/
tools/veri-cekici/*.xlsx
tools/veri-cekici/*_results.json
tools/veri-cekici/*_log.txt

/bootstrap/cache/*.php
sample_output.txt
route-list.txt

# FTP sifresi + OPS_SECRET icerir, asla commit edilmez (bkz. deploy/deploy.py,
# deploy/.env.deploy.example sablonu commit edilir).
/deploy/.env.deploy
/deploy/__pycache__/
log_output.txt
