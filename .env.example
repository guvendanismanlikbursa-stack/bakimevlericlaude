APP_NAME="BakimPlatform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@bakimplatform.test
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
CACHE_STORE=file
QUEUE_CONNECTION=sync

BRAND_DEFAULT=bakimevibul

# Public form hiz sinirlari (dakika basina istek, IP bazli) - opsiyonel,
# tanimlanmazsa config/platform.php > throttle icindeki varsayilanlar kullanilir.
# THROTTLE_PUBLIC_LIGHT=60
# THROTTLE_PUBLIC_FORM=20
# THROTTLE_PUBLIC_SENSITIVE=10
# THROTTLE_AUTH_ATTEMPT=5
# THROTTLE_AUTH_REGISTER=10

# Veri cekici ile olusturulan on kayitli kurumlara atanacak demo gorsel
# havuzunun yolu (kategori adina gore alt klasorlere ayrilmis olmali,
# bkz. App\Services\FacilityImportImageService). Tanimlanmazsa
# config/platform.php > import_image_pool_path varsayilani kullanilir.
# Windows'ta ters slash yerine / kullanin (dotenv ters slash'i escape
# karakteri sanip hata verir).
# IMPORT_IMAGE_POOL_PATH="C:/path/to/kurum-gorselleri"

# Yuzen WhatsApp butonunun varsayilan numarasi (Admin > Ayarlar'dan da
# degistirilebilir, deploy gerekmez). Tanimlanmazsa config/platform.php >
# default_whatsapp.number kullanilir.
# WHATSAPP_NUMBER=908503087991

# Production checklist (canliya cikmadan once bu degerlerle degistirin):
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://bakimevibul.com
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bakim_platform
# DB_USERNAME=production_user
# DB_PASSWORD=change-me
# SESSION_SECURE_COOKIE=true
# LOG_LEVEL=warning
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.saglayici.com
# MAIL_PORT=587
# MAIL_USERNAME=change-me
# MAIL_PASSWORD=change-me
# MAIL_ENCRYPTION=tls
# QUEUE_CONNECTION=database
# (config/queue.php ve jobs/failed_jobs migration'lari zaten repo'da mevcut,
# ekstra kurulum gerekmez; sadece migrate calistirin. Paylasimli (cPanel)
# hosting'de kalici supervisor/systemd servisi kurulamadigindan, kuyruk
# routes/console.php icindeki "queue:work --stop-when-empty" schedule
# girdisiyle mevcut "* * * * * php artisan schedule:run" cron'una
# (docs/PRODUCTION.md > 7) binerek her dakika tuketilir. sync birakilirsa
# mail/bildirim gonderimi (kurum sahiplenme onayi, e-posta dogrulama -
# bkz. FacilityEmailVerificationMail implements ShouldQueue) HTTP
# istegini bekletir.)

# Production'da beklenmeyen kritik hatalar bu adrese mail olarak bildirilir
# (bkz. bootstrap/app.php withExceptions + notify_admin_of_exception()).
# Tanimlanmazsa config/platform.php > admin_alert_email varsayilani kullanilir.
# ADMIN_ALERT_EMAIL=guvendanismanlikbursa@gmail.com