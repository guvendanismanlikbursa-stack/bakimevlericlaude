{
    "name":  "bakimplatform/multi-brand",
    "type":  "project",
    "description":  "Yasli bakim / cocuk ve rehabilitasyon merkezleri arama-eslestirme platformu - 3 marka, ortak veritabani ve admin panel",
    "require":  {
        "php": "^8.2",
        "laravel/framework": "^12.61.1",
        "laravel/socialite": "^5.28",
        "laravel/tinker": "^2.9",
        "minishlink/web-push": "^10.1",
        "sentry/sentry-laravel": "^4.26"
    },
    "require-dev":  {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.5"
    },
    "autoload":  {
                     "psr-4":  {
                                   "App\\":  "app/",
                                   "Database\\Factories\\":  "database/factories/",
                                   "Database\\Seeders\\":  "database/seeders/"
                               },
                     "files":  [
                                   "app/helpers.php"
                               ]
                 },
    "scripts":  {
                    "post-autoload-dump":  [
                                               "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
                                               "@php artisan package:discover --ansi"
                                           ]
                },
    "config":  {
                   "optimize-autoloader":  true,
                   "preferred-install":  "dist",
                   "sort-packages":  true
               },
    "minimum-stability":  "stable",
    "prefer-stable":  true,
    "autoload-dev":  {
                         "psr-4":  {
                                       "Tests\\":  "tests/"
                                   }
                     },
    "license": ["proprietary"]
}
