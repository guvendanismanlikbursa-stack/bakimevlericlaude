# deploy/deploy.py'nin okudugu gercek dosya deploy/.env.deploy'dur (bu dosyayi
# kopyalayip gercek degerleri doldurun). O dosya .gitignore'da, asla commit
# edilmez - FTP sifresi ve OPS_SECRET burada gecmemeli.

FTP_HOST=lumos.veridyen.com
FTP_USER=kullanici-adi
FTP_PASS=sifre

# 3 domain de production .env'deki OPS_SECRET ile ayni degere sahip olmali.
OPS_SECRET=uzun-rastgele-deger

# Sirasi onemli: DOC_ROOTS[i] her zaman DOMAINS[i]'ye karsilik gelir.
DOC_ROOTS=public_html,public_html_bakimevibul,bakimeviara.com
DOMAINS=bakimevleri.com,bakimevibul.com,bakimeviara.com
