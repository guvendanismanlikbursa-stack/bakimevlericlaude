APP_NAME="BakimPlatform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Istanbul
APP_URL=https://bakimevibul.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bakim_platform
DB_USERNAME=production_user
DB_PASSWORD=change-me

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
CACHE_STORE=file
# config/queue.php + jobs/failed_jobs migration'lari repoda mevcut; database
# secilirse ek kurulum gerekmez, sadece migrate + "php artisan queue:work"
# icin kalici bir supervisor/systemd servisi tanimlayin. sync birakilirsa
# mail/bildirim gonderimi (kurum sahiplenme onayi, e-posta dogrulama) HTTP
# istegini bekletir.
QUEUE_CONNECTION=database

BRAND_DEFAULT=bakimevibul

# Public form hiz sinirlari (dakika basina istek, IP bazli) - opsiyonel.
# THROTTLE_PUBLIC_LIGHT=60
# THROTTLE_PUBLIC_FORM=20
# THROTTLE_PUBLIC_SENSITIVE=10
# THROTTLE_AUTH_ATTEMPT=5
# THROTTLE_AUTH_REGISTER=10
IMPORT_IMAGE_POOL_PATH=/var/www/bakim-platform/storage/app/import-image-pool
IMPORT_IMAGE_COUNT=5
